{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist-scripts",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["scripts/**/*", "lib/**/*", "types/**/*"],
  "exclude": ["node_modules", ".next"]
}
